# API key for authenticating requests to /api/* endpoints.
# When set, all API requests must include an X-API-Key header with this value.
# Leave empty or remove to disable authentication (useful for local development).
SCREENSHOT_API_KEY=

# Allow localhost and loopback URLs (e.g. http://localhost:3000).
# Set to "true" to disable SSRF protection for localhost.
# Only use this for local development — never enable in production.
# Default: not set (localhost is blocked)
ALLOW_LOCALHOST=

# Maximum number of screenshots taken simultaneously.
# Each concurrent screenshot opens a browser tab (~50-150MB RAM).
# Default: 4
MAX_CONCURRENT=4

# Maximum number of requests that wait in line when all slots are busy.
# Requests beyond this limit are rejected immediately with 503.
# Default: 16
MAX_QUEUE=16
